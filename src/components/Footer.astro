---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-4 px-6 py-8 sm:flex-row sm:justify-between">
    <p class="text-sm text-gray-500 dark:text-gray-500">
      &copy; {currentYear} Rainiwalk
    </p>
    <p class="text-sm text-gray-400 dark:text-gray-600">
      Built with <a href="https://astro.build" class="text-accent hover:underline" target="_blank" rel="noopener noreferrer">Astro</a> &amp; <a href="https://tailwindcss.com" class="text-accent hover:underline" target="_blank" rel="noopener noreferrer">Tailwind</a>
    </p>
  </div>
</footer>
