---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  url?: string;
  status?: "active" | "archived" | "wip";
}

const { title, description, tags, github, url, status } = Astro.props;

const tagColorMap: Record<string, string> = {
  TypeScript: "tag-blue",
  JavaScript: "tag-blue",
  Kotlin: "tag-purple",
  Java: "tag-purple",
  "C++": "tag-blue",
  C: "tag-blue",
  Python: "tag-green",
  Astro: "tag-orange",
  "Tailwind CSS": "tag-pink",
  CSS: "tag-pink",
};

function getTagClass(tag: string): string {
  return tagColorMap[tag] ?? "tag-default";
}

const statusLabels = {
  active: "Active",
  archived: "Archived",
  wip: "In Progress",
};

const statusColors = {
  active: "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
  archived: "bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-500",
  wip: "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400",
};
---

<article
  class="group rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-gray-300 hover:shadow-md dark:border-gray-800 dark:bg-gray-900/50 dark:hover:border-gray-700"
>
  <div class="flex items-start justify-between">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
      {
        url ? (
          <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
            {title}
            <span class="ml-1 inline-block text-gray-400 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
          </a>
        ) : (
          title
        )
      }
    </h3>
    {status && (
      <span class:list={["rounded-full px-2.5 py-0.5 text-xs font-medium", statusColors[status]]}>
        {statusLabels[status]}
      </span>
    )}
  </div>

  <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
    {description}
  </p>

  <div class="mt-4 flex flex-wrap items-center gap-2">
    {tags.map((tag) => <span class:list={["tag", getTagClass(tag)]}>{tag}</span>)}
  </div>

  {github && (
    <div class="mt-4">
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-gray-500 transition-colors hover:text-accent dark:text-gray-500 dark:hover:text-accent"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        Source
      </a>
    </div>
  )}
</article>
