---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { projects } from "@/data/projects";
---

<BaseLayout
  title="Projects"
  description="Side projects and experiments by Rainiwalk."
>
  <section class="animate-fade-in">
    <h1 class="section-heading">Projects</h1>

    <p class="mb-8 text-gray-600 dark:text-gray-400">
      A collection of side projects, experiments, and things I've built to
      learn and explore new ideas.
    </p>

    {
      projects.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-1">
          {projects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-gray-300 py-16 text-center dark:border-gray-700">
          <p class="text-gray-500 dark:text-gray-500">
            Projects will be listed here soon.
          </p>
        </div>
      )
    }
  </section>
</BaseLayout>
