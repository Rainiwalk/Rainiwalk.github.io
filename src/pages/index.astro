---
import BaseLayout from "@/layouts/BaseLayout.astro";

const focusAreas = [
  { label: "Android Audio Framework", icon: "🎧" },
  { label: "Audio Systems", icon: "🔊" },
  { label: "AI-assisted Development", icon: "🤖" },
  { label: "Developer Tooling", icon: "🛠️" },
];
---

<BaseLayout title="Home">
  <section class="animate-fade-in py-8">
    <div class="space-y-6">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Hi, I'm Rainiwalk.
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
          I'm a Software Engineer currently working on Android Audio Framework
          development.
        </p>
      </div>

      <div class="prose-custom space-y-4">
        <p>
          My interests include Android platform internals, audio systems,
          AI-assisted development, and developer tooling.
        </p>
        <p>
          I enjoy exploring how modern AI tools can improve software engineering
          workflows and help developers understand complex systems.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-12 animate-slide-up">
    <h2 class="section-heading">Currently Focused On</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        focusAreas.map(({ label, icon }) => (
          <div class="flex items-center gap-3 rounded-lg border border-gray-200 bg-white p-4 transition-colors dark:border-gray-800 dark:bg-gray-900/50">
            <span class="text-xl">{icon}</span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
              {label}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-12 animate-slide-up">
    <h2 class="section-heading">Latest</h2>
    <div class="space-y-4">
      <a
        href="/projects"
        class="group flex items-center justify-between rounded-lg border border-gray-200 bg-white p-4 transition-all hover:border-gray-300 hover:shadow-sm dark:border-gray-800 dark:bg-gray-900/50 dark:hover:border-gray-700"
      >
        <div>
          <h3 class="font-medium text-gray-900 dark:text-white">Projects</h3>
          <p class="text-sm text-gray-500 dark:text-gray-500">
            Side projects and experiments
          </p>
        </div>
        <span class="text-gray-400 transition-transform group-hover:translate-x-1">→</span>
      </a>
      <a
        href="/about"
        class="group flex items-center justify-between rounded-lg border border-gray-200 bg-white p-4 transition-all hover:border-gray-300 hover:shadow-sm dark:border-gray-800 dark:bg-gray-900/50 dark:hover:border-gray-700"
      >
        <div>
          <h3 class="font-medium text-gray-900 dark:text-white">About</h3>
          <p class="text-sm text-gray-500 dark:text-gray-500">
            Background and what I'm working on now
          </p>
        </div>
        <span class="text-gray-400 transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
